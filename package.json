{
  "name": "@mythosforge/forgeengine",
  "version": "0.1.0",
  "description": "ForgeEngine — agent-native deterministic game engine: any AI can build and play games for it, safely. Replay-verifiable core, fail-closed safety gate, bounded spec vocabulary, Farcaster-native.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx \"test/**/*.test.ts\"",
    "dev": "vite",
    "build:web": "vite build",
    "arena": "tsx src/arena/demo.ts",
    "kit": "tsx src/kit/cli.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "@farcaster/miniapp-sdk": "^0.3.0",
    "phaser": "^3.90.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryjin111/forgeengine.git"
  }
}
